# Copia este archivo a .env y completa los valores reales
# NUNCA subas .env al repositorio

DATABASE_URL=postgresql+psycopg://optica:TU_PASSWORD_DB@db:5432/optica

# Genera un secreto fuerte con:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=CAMBIA_ESTO_POR_SECRETO_ALEATORIO_DE_48_CHARS

ENV=dev

# WhatsApp Business API (Meta)
# Obtener en: https://developers.facebook.com/apps → WhatsApp → API Setup
WA_TOKEN=TU_TOKEN_WHATSAPP_BUSINESS
WA_PHONE_ID=TU_PHONE_ID_META
WA_BIRTHDAY_TEMPLATE=cumpleanos_optica
WA_BIRTHDAY_LANG=es
