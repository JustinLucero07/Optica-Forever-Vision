# Copiar a .env y rellenar los valores reales

DATABASE_URL=postgresql+psycopg://optica:optica@db:5432/optica
JWT_SECRET=cambiar-en-produccion

# WhatsApp Business API (Meta)
# Obtener en: https://developers.facebook.com/apps → WhatsApp → API Setup
WA_TOKEN=          # Token de acceso permanente (o temporal para pruebas)
WA_PHONE_ID=       # ID del número de teléfono en Meta Business Manager

# Nombre de la plantilla de cumpleaños aprobada en Meta Business Manager
# La plantilla debe estar aprobada en español antes de usarla
WA_BIRTHDAY_TEMPLATE=cumpleanos_optica
WA_BIRTHDAY_LANG=es
