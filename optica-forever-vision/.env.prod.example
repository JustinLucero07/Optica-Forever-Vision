# ============================================================
#  Óptica Forever Vision — Variables de entorno (PRODUCCIÓN)
#  Copia este archivo a .env.prod y rellena los valores reales
#  NUNCA subas .env.prod al repositorio
# ============================================================

# ── Base de datos ─────────────────────────────────────────
DB_USER=optica
DB_PASSWORD=CAMBIA_ESTO_POR_CONTRASENA_SEGURA
DB_NAME=optica

# ── Redis ─────────────────────────────────────────────────
REDIS_PASSWORD=CAMBIA_ESTO_POR_CONTRASENA_SEGURA

# ── Dominio (sin http:// ni barra final) ──────────────────
DOMAIN=tudominio.com

# ── JWT — genera con: openssl rand -hex 32 ────────────────
JWT_SECRET=CAMBIA_ESTO_POR_SECRET_ALEATORIO

# ── Entorno ───────────────────────────────────────────────
ENV=prod

# ── WhatsApp Business API (Meta Cloud API) ────────────────
WA_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxx
WA_PHONE_ID=1234567890123
WA_BIRTHDAY_TEMPLATE=cumpleanos_optica
WA_BIRTHDAY_LANG=es
